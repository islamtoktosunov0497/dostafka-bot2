datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id         Int      @id @default(autoincrement())
  telegramId BigInt   @unique
  firstName  String?
  lastName   String?
  username   String?
  phone      String?
  orders     Order[]
  createdAt  DateTime @default(now())
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  price       Float
  image       String?
  createdAt   DateTime @default(now())
}

model Order {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  items      Json     // Array of items { productId, name, price, quantity }
  totalPrice Float
  address    String?
  phone      String?
  status     String   @default("PENDING")

  createdAt  DateTime @default(now())
}
